# ── Polymarket Bot Configuration ────────────────────────
# Copy file ini ke .env lalu isi nilainya
# cp .env.example .env

# ── Wallet (LIVE mode only) ──────────────────────────────
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLY_RPC=https://polygon-rpc.com

# ── Telegram Alerts ──────────────────────────────────────
TELEGRAM_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Proxy (proxies.fo) ───────────────────────────────────
# Format HTTP:   http://USERNAME:PASSWORD@gate.proxies.fo:PORT
# Format SOCKS5: socks5://USERNAME:PASSWORD@gate.proxies.fo:PORT
# Kosongkan jika tidak pakai proxy
PROXY_URL=
